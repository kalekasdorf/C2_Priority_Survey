// ---------------------------------------------------------------
// Google Apps Script backend for the Community Priority Ballot
//
// SETUP:
// 1. Go to sheets.google.com, create a new blank spreadsheet.
//    Name it something like "Priority Survey Responses".
// 2. In that sheet, go to Extensions > Apps Script.
// 3. Delete any starter code in the editor and paste this entire file in.
// 4. Click the Save icon (disk).
// 5. Click "Deploy" (top right) > "New deployment".
//    - Click the gear icon next to "Select type" > choose "Web app".
//    - Description: anything, e.g. "Priority survey endpoint".
//    - Execute as: "Me".
//    - Who has access: "Anyone".
//    - Click "Deploy".
// 6. Google will ask you to authorize the script — click through the
//    "Advanced" / "Go to (unsafe)" prompts. This is expected for your
//    own scripts; it's just Google being cautious about unverified apps.
// 7. Copy the "Web app URL" it gives you (ends in /exec).
// 8. Paste that URL into the SCRIPT_URL constant in index.html.
// ---------------------------------------------------------------

function doPost(e) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Responses')
    || SpreadsheetApp.getActiveSpreadsheet().insertSheet('Responses');

  const params = e.parameter;

  // Build header row on first submission
  if (sheet.getLastRow() === 0) {
    const headers = ['Timestamp'];
    let i = 1;
    while (params['item_' + i]) {
      headers.push(params['item_' + i]);
      i++;
    }
    sheet.appendRow(headers);
  }

  // Build the data row in the same column order as headers
  const headerRow = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
  const row = headerRow.map((header, colIdx) => {
    if (colIdx === 0) return params.timestamp || new Date().toISOString();
    // find matching item_N whose value equals this header, then use votes_N
    let i = 1;
    while (params['item_' + i]) {
      if (params['item_' + i] === header) {
        return params['votes_' + i] || 0;
      }
      i++;
    }
    return '';
  });

  sheet.appendRow(row);

  return ContentService.createTextOutput(JSON.stringify({ status: 'ok' }))
    .setMimeType(ContentService.MimeType.JSON);
}

function doGet(e) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Responses');

  if (!sheet || sheet.getLastRow() < 2) {
    return ContentService.createTextOutput(JSON.stringify({ totals: {}, respondents: 0 }))
      .setMimeType(ContentService.MimeType.JSON);
  }

  const data = sheet.getDataRange().getValues();
  const headers = data[0];
  const rows = data.slice(1);

  const totals = {};
  for (let col = 1; col < headers.length; col++) {
    totals[headers[col]] = 0;
  }

  rows.forEach(row => {
    for (let col = 1; col < headers.length; col++) {
      const val = Number(row[col]) || 0;
      totals[headers[col]] += val;
    }
  });

  return ContentService.createTextOutput(JSON.stringify({
    totals: totals,
    respondents: rows.length
  })).setMimeType(ContentService.MimeType.JSON);
}
